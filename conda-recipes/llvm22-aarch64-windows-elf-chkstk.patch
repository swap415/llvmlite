Fix "invalid fixup for add (uimm12) instruction" for windows-triple + ELF
targets using the large code model (llvmlite/numba MCJIT compiles with
aarch64-pc-windows-msvc-elf and CodeModel::Large; any function whose frame
reaches the Windows stack-probe size, 4 KiB, hits this).

emitWindowsStackProbe materializes the __chkstk address under
CodeModel::Large with MOVaddrEXT (ADRP+ADD) whose external-symbol operands
carry no MO_PAGE / MO_PAGEOFF|MO_NC target flags. The COFF object writer
does not care - it maps fixup_aarch64_add_imm12 to
IMAGE_REL_ARM64_PAGEOFFSET_12A from the fixup kind alone - but on ELF
AArch64MCInstLower only attaches the :lo12: specifier when the operand
carries MO_PAGEOFF|MO_NC, so AArch64ELFObjectWriter::getRelocType reports
"invalid fixup for add (uimm12) instruction" and object emission fails.

Keep the large code model semantics (required for the JIT: nothing bounds
the span between JIT-allocated code segments, so small-model PC-relative
addressing may silently overflow) and materialize the address with the
canonical large-code-model MOVZ/MOVK sequence instead, exactly as ISel
(getAddrLarge) and FastISel (materializeGV) do for every other symbol:
MOVZ :abs_g3: / MOVK :abs_g2_nc: / :abs_g1_nc: / :abs_g0_nc:. The
resulting R_AARCH64_MOVW_UABS_G3/G2_NC/G1_NC/G0_NC relocations are
range-unlimited, supported by the ELF object writer, and resolved by
RuntimeDyldELF (they are the same relocations it builds its own far-call
stubs from). COFF output is unchanged.

diff --git a/llvm/lib/Target/AArch64/AArch64PrologueEpilogue.cpp b/llvm/lib/Target/AArch64/AArch64PrologueEpilogue.cpp
--- a/llvm/lib/Target/AArch64/AArch64PrologueEpilogue.cpp
+++ b/llvm/lib/Target/AArch64/AArch64PrologueEpilogue.cpp
@@ -1151,10 +1151,38 @@
     break;
   case CodeModel::Large:
-    BuildMI(MBB, MBBI, DL, TII->get(AArch64::MOVaddrEXT))
-        .addReg(AArch64::X16, RegState::Define)
-        .addExternalSymbol(ChkStk)
-        .addExternalSymbol(ChkStk)
-        .setMIFlags(MachineInstr::FrameSetup);
+    if (Subtarget.isTargetCOFF()) {
+      BuildMI(MBB, MBBI, DL, TII->get(AArch64::MOVaddrEXT))
+          .addReg(AArch64::X16, RegState::Define)
+          .addExternalSymbol(ChkStk)
+          .addExternalSymbol(ChkStk)
+          .setMIFlags(MachineInstr::FrameSetup);
+    } else {
+      // MOVaddrEXT's flag-less operands cannot be lowered for ELF: without
+      // MO_PAGEOFF|MO_NC no :lo12: specifier is attached and the object
+      // writer rejects the ADD fixup ("invalid fixup for add (uimm12)
+      // instruction"). Use the canonical large-code-model MOVZ/MOVK
+      // materialization instead (range-unlimited MOVW_UABS relocations,
+      // also resolved by the JIT linkers).
+      BuildMI(MBB, MBBI, DL, TII->get(AArch64::MOVZXi), AArch64::X16)
+          .addExternalSymbol(ChkStk, AArch64II::MO_G3)
+          .addImm(48)
+          .setMIFlags(MachineInstr::FrameSetup);
+      BuildMI(MBB, MBBI, DL, TII->get(AArch64::MOVKXi), AArch64::X16)
+          .addReg(AArch64::X16)
+          .addExternalSymbol(ChkStk, AArch64II::MO_G2 | AArch64II::MO_NC)
+          .addImm(32)
+          .setMIFlags(MachineInstr::FrameSetup);
+      BuildMI(MBB, MBBI, DL, TII->get(AArch64::MOVKXi), AArch64::X16)
+          .addReg(AArch64::X16)
+          .addExternalSymbol(ChkStk, AArch64II::MO_G1 | AArch64II::MO_NC)
+          .addImm(16)
+          .setMIFlags(MachineInstr::FrameSetup);
+      BuildMI(MBB, MBBI, DL, TII->get(AArch64::MOVKXi), AArch64::X16)
+          .addReg(AArch64::X16)
+          .addExternalSymbol(ChkStk, AArch64II::MO_G0 | AArch64II::MO_NC)
+          .addImm(0)
+          .setMIFlags(MachineInstr::FrameSetup);
+    }
     if (NeedsWinCFI) {
       HasWinCFI = true;
       BuildMI(MBB, MBBI, DL, TII->get(AArch64::SEH_Nop))
